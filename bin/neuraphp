#!/usr/bin/env php
<?php

declare(strict_types=1);

use B7s\Neuraphp\Console\Application;

$autoloader = null;
$candidates = [
    __DIR__ . '/../vendor/autoload.php',
    __DIR__ . '/../../../autoload.php',
    __DIR__ . '/../../autoload.php',
];
foreach ($candidates as $path) {
    if (file_exists($path)) {
        $autoloader = $path;
        break;
    }
}

require_once $autoloader;

$application = new Application();
$application->run();